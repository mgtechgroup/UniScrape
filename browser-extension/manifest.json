{
  "manifest_version": 3,
  "name": "UniScrape Search",
  "version": "1.0.0",
  "description": "Universal adult media search — 800+ sources, torrents, streams, files",
  "permissions": ["storage", "contextMenus", "tabs"],
  "host_permissions": ["http://localhost:8085/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://*/*", "http://*/*"],
    "js": ["content.js"]
  }]
}
